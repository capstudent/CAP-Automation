# OIT Automation environment template
# Copy this file to .env and fill in your values.

# Google Sheets (service account)
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_CREDENTIALS_FILE=

# Google OAuth (used by frontend OAuth flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/api/sheets/oauth/callback

# MyAccount defaults (optional; can also be entered in UI)
MYACCOUNT_USERNAME=
MYACCOUNT_PASSWORD=

# Flask server settings
# Set FLASK_ENV=production on your deployed server. This enables:
#   - Secure session cookies (HTTPS only)
#   - ProxyFix middleware (trusts X-Forwarded-* headers from nginx/Railway/Render)
#   - Headless Chrome by default
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5001

# Change this in shared environments (use `python -c "import secrets; print(secrets.token_hex(32))"`)
SECRET_KEY=dev-secret-key-change-in-production

# Selenium: override the default. Defaults to headless when FLASK_ENV=production.
# SELENIUM_HEADLESS=true
